# === DATABASE (Supabase PostgreSQL) ===
# 1. Buka https://supabase.com → New Project
# 2. Settings → Database → Connection string (URI mode)
# Gunakan Connection Pooler (port 6543) untuk kompatibilitas Vercel (IPv4)
DATABASE_URL="postgresql://postgres:password@xxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Alternatif Direct Connection (IPv6-only):
# DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# === SUPABASE REST ===
# Settings → API → Project URL + service_role key
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# === NEXTAUTH ===
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://clover-two-ashy.vercel.app"
