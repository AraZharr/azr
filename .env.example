# ============================================================
# CLOVER — Telegram AI Assistant Bot
# Environment Variables Template
# Copy to .env.local and fill in all values
# ============================================================

# ----------------------------
# TELEGRAM
# ----------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# ----------------------------
# SUPABASE
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ----------------------------
# AI PROVIDERS
# ----------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ----------------------------
# APP CONFIG
# ----------------------------
# Telegram user IDs who are bot admins (comma-separated)
BOT_ADMIN_TELEGRAM_IDS=123456789,987654321

# AI provider defaults
DEFAULT_PROVIDER=gemini
FALLBACK_ORDER=groq,openrouter

# Rate limits
DAILY_MESSAGE_LIMIT=100
DAILY_MESSAGE_LIMIT_GROUP=50

# Memory limits
SESSION_MEMORY_LIMIT=25
LONG_TERM_MEMORY_LIMIT=50
SUMMARY_MEMORY_LIMIT=5

# App URL (required for setting webhook)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
