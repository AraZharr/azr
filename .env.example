# Turso Database
TURSO_DATABASE_URL=libsql://azr-db-arazharr.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=<your-turso-token>

# Web Domain
NEXT_PUBLIC_URL=https://azr.vercel.app

# WhatsApp
NEXT_PUBLIC_WA_NUMBER=6281234567890

# Gemini AI (chatbot)
GEMINI_API_KEY=<your-gemini-key>
GEMINI_MODEL=gemini-2.0-flash

# Groq AI (fallback)
GROQ_API_KEY=<your-groq-key>
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudflare Turnstile (anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<your-site-key>
TURNSTILE_SECRET_KEY=<your-secret-key>

# Optional: Session/privacy
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GITHUB_REPO=https://github.com/AraZharr/azr